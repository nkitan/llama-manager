{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "llama-manager",
  "version": "0.1.0",
  "identifier": "com.llamamanager.app",
  "build": {
    "beforeDevCommand": "cd src-ui && trunk serve",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd src-ui && trunk build",
    "frontendDist": "../src-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Llama Manager",
        "width": 1280,
        "height": 832,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": true,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
